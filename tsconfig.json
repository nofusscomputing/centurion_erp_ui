{
    "compilerOptions": {
        "target": "ES2022",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "allowJs": true,
        "checkJs": false,
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,

        "types": [
            "@testing-library/jest-dom",
            "@testing-library/react",
            "@testing-library/user-event",
            "jest",
        ]
    },
    "include": [
        "src",
        "types"
    ]
}